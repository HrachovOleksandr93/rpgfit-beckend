# =============================================================================
# RPGFit Backend - Environment Variables
# =============================================================================
# Copy this file to .env.local and adjust values for your environment.
# DO NOT commit .env.local or any file containing real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Symfony Framework
# -----------------------------------------------------------------------------
# Application environment: dev, test, prod
APP_ENV=dev

# Secret used for CSRF tokens, session signing, etc. MUST be changed in production.
APP_SECRET=change_me_in_production

# Public URL of the application (used for generating absolute URLs)
APP_URL=https://rpgfit.local:8443

# Default URI for generating URLs in CLI commands
DEFAULT_URI=https://rpgfit.local

# -----------------------------------------------------------------------------
# Database (MySQL)
# -----------------------------------------------------------------------------
# Individual database connection parameters
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=rpgfit
DB_USER=rpgfit_user
DB_PASSWORD=rpgfit_password

# Composed DATABASE_URL (uses individual vars above)
DATABASE_URL="mysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?serverVersion=8.0&charset=utf8mb4"

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Individual Redis connection parameters
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Composed REDIS_URL (uses individual vars above)
REDIS_URL="redis://${REDIS_HOST}:${REDIS_PORT}"

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# Regex pattern for allowed origins
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1|rpgfit\.local)(:[0-9]+)?$'

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# Path to the private key for signing JWT tokens
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem

# Path to the public key for verifying JWT tokens
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem

# Passphrase for the JWT private key
JWT_PASSPHRASE=rpgfit_secret

# JWT token time-to-live in seconds (default: 1 hour)
JWT_TOKEN_TTL=3600

# -----------------------------------------------------------------------------
# Docker Compose (only used by docker-compose.yml, not by the Symfony app)
# These are defined in .env.docker for Docker environments.
# -----------------------------------------------------------------------------
# MYSQL_ROOT_PASSWORD=root_password
# MYSQL_DATABASE=rpgfit
# MYSQL_USER=rpgfit_user
# MYSQL_PASSWORD=rpgfit_password
# MYSQL_PORT=3306
# REDIS_PORT=6379
# NGINX_PORT=8080
# NGINX_SSL_PORT=8443
