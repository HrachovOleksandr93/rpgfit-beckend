# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
SYMFONY_DEPRECATIONS_HELPER=999999

# Use SQLite for tests (no external DB dependency)
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_test.db"

# Redis disabled in tests (use in-memory or skip)
REDIS_URL="redis://127.0.0.1:6379"

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=rpgfit_secret
JWT_TOKEN_TTL=3600
###< lexik/jwt-authentication-bundle ###

###> test-harness ###
# Harness is live in CI so functional tests can hit /api/test/*.
APP_TESTING_ENABLED=true
###< test-harness ###
